+  Rooted<ReadableByteStreamController*> controller(
+      cx, unwrappedRequest->controller());
+
+  // Assert: this.[[view]].[[ByteLength]] > 0.
+  // Assert: this.[[view]].[[ViewedArrayBuffer]].[[ByteLength]] > 0.
+  // MOZ_ASSERT(len > 0);
