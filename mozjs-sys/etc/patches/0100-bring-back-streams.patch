+  // TypeError exception.
+  if (buffer->maybeUnwrapAs<js::ArrayBufferObject>()->isDetached()) {
+    JS_ReportErrorNumberASCII(cx, GetErrorMessage, nullptr,
+                              JSMSG_READABLESTREAMBYOBREQUEST_RESPOND_DETACHED);
+    return false;
+  }
